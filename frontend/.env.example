# Backend API base URL (no trailing slash). Leave empty for local dev (Vite proxies /api).
# Example: VITE_API_BASE=https://your-backend.hf.space
VITE_API_BASE=

# Mappls (MapmyIndia) Web Map SDK key.
# Create a project at https://apps.mappls.com/ and copy the REST / Map SDK Key.
# Whitelist your serving domain(s) on the key (e.g. your Vercel URL) under
# "Whitelisted IPs & Domains", or the SDK returns 401. If unset, the map area
# shows a "set VITE_MAPPLS_KEY" placeholder.
VITE_MAPPLS_KEY=
